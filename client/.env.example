# ============================================================
#  HimOrganic – Frontend (Vite) Environment Variables
#  Copy this file to .env.local and fill in the values.
#  Variables must start with VITE_ to be exposed to the client.
# ============================================================

# ------------------------------------------------------------
# Backend API base URL (without /api)
# ------------------------------------------------------------
VITE_API_URL=https://your-backend-host.com

# ------------------------------------------------------------
# UPI Payment
# Set to your verified merchant UPI Virtual Payment Address.
# ------------------------------------------------------------
VITE_MERCHANT_UPI=your-upi-id@bank
VITE_MERCHANT_NAME=Himorganic

# ------------------------------------------------------------
# Contact form provider
# ------------------------------------------------------------
VITE_WEB3FORMS_KEY=replace-with-web3forms-access-key
