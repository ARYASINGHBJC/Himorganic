# ============================================================
#  HimOrganic – Frontend (Vite) Environment Variables
#  Copy this file to .env.local and fill in the values.
#  Variables must start with VITE_ to be exposed to the client.
# ============================================================

# ------------------------------------------------------------
# UPI Payment
# Set to your verified merchant UPI Virtual Payment Address.
# ------------------------------------------------------------
VITE_MERCHANT_UPI=himorganic@upi
VITE_MERCHANT_NAME=Himorganic
