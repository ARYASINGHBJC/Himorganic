# ============================================================
#  HimOrganic – Backend Environment Variables
#  Copy this file to .env and fill in all values before
#  starting the server in production.
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ------------------------------------------------------------
# Database
# Set DB_TYPE=mongodb for production.
# Leave as 'json' only for local development.
# ------------------------------------------------------------
DB_TYPE=mongodb
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/himorganic?retryWrites=true&w=majority

# ------------------------------------------------------------
# JWT Authentication
# Use a long, random string (min 64 chars) for JWT_SECRET.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=replace-with-a-very-long-random-secret-string

# ------------------------------------------------------------
# CORS – allowed frontend origin(s)
# Comma-separated list handled by server.js
# ------------------------------------------------------------
CLIENT_ORIGIN=https://yourdomain.com

# ------------------------------------------------------------
# SMS / OTP  (required for phone-number login in production)
# Supported providers: twilio, msg91
# Leave SMS_PROVIDER unset (or empty) to disable OTP login.
# ------------------------------------------------------------
SMS_PROVIDER=twilio

# ── Twilio ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # Twilio-verified sender number or Messaging Service SID

# ── MSG91 (alternative to Twilio) ───────────────────────────
# MSG91_API_KEY=your_msg91_api_key
# MSG91_TEMPLATE_ID=your_otp_template_id
# MSG91_SENDER_ID=HIMORG
