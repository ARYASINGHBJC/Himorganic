# ============================================================
#  HimOrganic – Backend Environment Variables
#  Copy this file to .env and fill in all values before
#  starting the server in production.
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
NODE_ENV=production

# ------------------------------------------------------------
# Database
# Set DB_TYPE=mongodb for production.
# Leave as 'json' only for local development.
# ------------------------------------------------------------
DB_TYPE=mongodb
MONGODB_URI=mongodb+srv://himorganic_user:W9TfbnO5OttzBhxA@cluster0.z11lj0q.mongodb.net/himorganic?retryWrites=true&w=majority

# ------------------------------------------------------------
# JWT Authentication
# Use a long, random string (min 64 chars) for JWT_SECRET.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=ad4f8bb5462bf0ed6b66dc22746dc635081614204120d3c283009ea73db68b25975a4b9fe3dba5e515efa07b4ffbf759f275a36c5c0899340fa0d0194bee82a6

# ------------------------------------------------------------
# CORS – allowed frontend origin(s)
# Comma-separated list handled by server.js
