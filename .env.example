# ============================================================
#  HimOrganic – Backend Environment Variables
#  Copy this file to .env and fill in all values before
#  starting the server in production.
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ------------------------------------------------------------
# Database
# Set DB_TYPE=mongodb for production.
# Leave as 'json' only for local development.
# ------------------------------------------------------------
DB_TYPE=mongodb
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/himorganic?retryWrites=true&w=majority

# ------------------------------------------------------------
# JWT Authentication
# Use different long random strings (min 64 chars each).
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# ------------------------------------------------------------
# CORS – allowed frontend origin(s)
# Frontend origin URL
# ------------------------------------------------------------
CLIENT_ORIGIN=https://himorganic.netlify.app

# ------------------------------------------------------------
# OTP / SMS provider
# ------------------------------------------------------------
SMS_PROVIDER=fast2sms
FAST2SMS_API_KEY=replace-with-fast2sms-api-key

# Optional alternatives
# TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
# TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# MSG91_API_KEY=replace-with-msg91-key
# MSG91_TEMPLATE_ID=replace-with-msg91-template-id
# MSG91_SENDER_ID=HIMORG

# ------------------------------------------------------------
# Frontend values (set in client/.env or Netlify env vars)
# ------------------------------------------------------------
# VITE_API_URL=https://your-backend-host.com
# VITE_MERCHANT_UPI=your-upi-id@bank
# VITE_MERCHANT_NAME=Himorganic
# VITE_WEB3FORMS_KEY=replace-with-web3forms-key
